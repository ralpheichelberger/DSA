OPENAI_API_KEY=
MINEA_EMAIL=
MINEA_PASSWORD=
# Force in-memory Minea stub (5 fake products) even when email/password are set — e.g. smoke-test sets this.
# MINEA_STUB=false
# Login tries AWS Cognito USER_PASSWORD_AUTH first (no browser). Set to skip and use Rod only:
# MINEA_SKIP_COGNITO=false
# MINEA_COGNITO_REGION=eu-west-1
# MINEA_COGNITO_CLIENT_ID=11idn2ot5orv6dm4f68lkrfu7d
# Optional: defaults are the live app (www.minea.com/login is not the real UI).
# MINEA_LOGIN_URL=https://app.minea.com/en/login/quickview?from=%2F
# MINEA_GRAPHQL_URL=https://y5ec7qy3bzbkxm6udp4u3o3lee.appsync-api.eu-west-1.amazonaws.com/graphql
# MINEA_ORIGIN=https://app.minea.com
# MINEA_USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36
# If Minea rotates AppSync, export a HAR while logged in and run: go run ./cmd/import-minea-har your.har
# RPC search pagination (searchAds fallback). Defaults: page 1, 3 pages total.
# MINEA_PAGE=1
# MINEA_PAGES=3
# MINEA_AD_MEDIA_INCLUDES=video
# MINEA_AD_PUBLICATION_DATE=last_2_weeks
# MINEA_AD_IS_ACTIVE=active
# MINEA_AD_LANGUAGES=de
# MINEA_AD_COUNTRIES=GB,DE,FR,ES,IT,PL,NL,AT,BE,CZ,DK,FI,GR,HU,IE,LU,PT,RO,SE,SK
# MINEA_AD_DAYS_RUNNING=7,30
# MINEA_AD_CTA_INCLUDES=SHOP_NOW,BUY_NOW,LEARN_MORE
# MINEA_CPM_VALUE=9
# MINEA_EXCLUDE_BAD_DATA=true
# MINEA_CREDIT_COST_PER_SEARCH=20
# MINEA_MIN_SAFE_CREDITS=100
# MINEA_ALERT_CREDITS=200
# MINEA_MAX_CREDITS_PER_SESSION=200
# MINEA_SLOW_LOGIN=false
# Rod uses Chromium with --no-sandbox on login (required on many Linux setups).
SUP_API_KEY=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
TIKTOK_ACCESS_TOKEN=
SHOPIFY_TECH_DOMAIN=
SHOPIFY_PETS_DOMAIN=
DB_PATH=./data/agent.db
# Comma-separated Minea niches for each agent discover cycle (trending/radar). Examples: pets | tech,pets
# AGENT_DISCOVERY_NICHES=tech,pets
# First agent cycle runs after this many hours (no scrape on process startup).
AGENT_INTERVAL_HOURS=6
AUTO_APPROVE=false
PORT=8080
DEV_MODE=true
# OWNER COMMUNICATION
# At least one channel should be configured for critical alerts.
# If none are configured, alerts are logged only (dashboard-only mode).
NOTIFY_EMAIL=
NOTIFY_SMTP_HOST=smtp.gmail.com
NOTIFY_SMTP_PORT=587
NOTIFY_SMTP_USER=
NOTIFY_SMTP_PASSWORD=
NOTIFY_SLACK_WEBHOOK=
NOTIFY_DISCORD_WEBHOOK=
NOTIFY_TELEGRAM_BOT_TOKEN=
NOTIFY_TELEGRAM_CHAT_ID=
NOTIFY_MIN_SEVERITY=critical
